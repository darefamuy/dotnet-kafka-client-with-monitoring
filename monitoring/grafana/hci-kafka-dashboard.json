{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "HCI Solutions — Kafka Client Metrics (Module 1). Monitor producer throughput, consumer lag, broker RTT, and DLQ activity.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Producer Metrics",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "id": 1,
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table" } },
      "targets": [
        {
          "expr": "rate(hci_kafka_produced_total[1m])",
          "legendFormat": "{{topic}}",
          "refId": "A"
        }
      ],
      "title": "Producer Throughput (msg/sec)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "ms", "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "kafka_producer_broker_rtt_p99_ms",
          "legendFormat": "P99 RTT {{broker}}",
          "refId": "A"
        }
      ],
      "title": "Producer → Broker P99 RTT",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "id": 3,
      "targets": [
        {
          "expr": "kafka_producer_queue_messages",
          "legendFormat": "Queue depth {{client_id}}",
          "refId": "A"
        }
      ],
      "title": "Producer Queue Depth",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "Consumer Metrics",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10000 },
              { "color": "red", "value": 50000 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "max(kafka_consumer_partition_lag) by (client_id, topic)",
          "legendFormat": "{{topic}} ({{client_id}})",
          "refId": "A"
        }
      ],
      "title": "Consumer Lag — Max Across Partitions",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 5,
      "targets": [
        {
          "expr": "kafka_consumer_partition_lag",
          "legendFormat": "{{topic}}[{{partition}}]",
          "refId": "A"
        }
      ],
      "title": "Consumer Lag per Partition",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "id": 6,
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(hci_kafka_processing_duration_seconds_bucket[5m]))",
          "legendFormat": "P99 {{topic}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(hci_kafka_processing_duration_seconds_bucket[5m]))",
          "legendFormat": "P95 {{topic}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.50, rate(hci_kafka_processing_duration_seconds_bucket[5m]))",
          "legendFormat": "P50 {{topic}}",
          "refId": "C"
        }
      ],
      "title": "Message Processing Latency (P50/P95/P99)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "id": 7,
      "targets": [
        {
          "expr": "rate(hci_kafka_consumed_total[1m])",
          "legendFormat": "{{topic}} ({{consumer_group}})",
          "refId": "A"
        }
      ],
      "title": "Consumer Throughput (msg/sec)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 },
      "id": 102,
      "title": "Data Quality & DLQ",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 27 },
      "id": 8,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "increase(hci_kafka_dlq_messages_total[1h])",
          "legendFormat": "{{source_topic}} ({{error_type}})",
          "refId": "A"
        }
      ],
      "title": "DLQ Messages (last 1h)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 27 },
      "id": 9,
      "targets": [
        {
          "expr": "rate(hci_kafka_produce_errors_total[5m])",
          "legendFormat": "{{topic}} ({{error_code}})",
          "refId": "A"
        }
      ],
      "title": "Produce Error Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 27 },
      "id": 10,
      "targets": [
        {
          "expr": "rate(hci_kafka_validation_errors_total[5m])",
          "legendFormat": "{{rule_name}}",
          "refId": "A"
        }
      ],
      "title": "Validation Error Rate by Rule",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["kafka", "hci", "galenica", "confluent"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "Europe/Zurich",
  "title": "HCI Kafka — Module 1 Client Metrics",
  "uid": "hci-kafka-module1",
  "version": 1
}
